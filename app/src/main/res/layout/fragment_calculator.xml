<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Statistical Calculator"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/primary_dark"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <!-- Distribution Selection Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select Distribution"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="8dp" />

                <RadioGroup
                    android:id="@+id/distribution_radio_group"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <!-- Z: only needs Z value -->
                    <RadioButton
                        android:id="@+id/radio_normal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Normal (Z)  —  Z value"
                        android:textSize="14sp"
                        android:checked="true" />

                    <!-- t: df + α -->
                    <RadioButton
                        android:id="@+id/radio_t"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Student's t  —  df + α"
                        android:textSize="14sp" />

                    <!-- χ²: df + α -->
                    <RadioButton
                        android:id="@+id/radio_chisquare"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chi-square (χ²)  —  df + α"
                        android:textSize="14sp" />

                    <!-- F: df1 + df2 + α -->
                    <RadioButton
                        android:id="@+id/radio_f"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="F Distribution  —  df₁ + df₂ + α"
                        android:textSize="14sp" />

                    <!-- Log: base + value -->
                    <RadioButton
                        android:id="@+id/radio_log"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Log  —  base + value"
                        android:textSize="14sp" />

                </RadioGroup>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Parameters Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/params_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Enter Parameters"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/params_hint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Enter a Z-score to find its cumulative probability."
                    android:textSize="12sp"
                    android:textColor="@color/text_hint"
                    android:layout_marginBottom="12dp" />

                <!-- ── NORMAL: Z value only ── -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/z_score_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    style="@style/InputStyle"
                    android:hint="Z-Score">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/z_score_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal|numberSigned" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- ── T / χ²: df ── -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/df_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    style="@style/InputStyle"
                    android:hint="Degrees of Freedom (df)"
                    android:visibility="gone">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/df_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Observed t-value (kept for future use / backward compat but hidden by default) -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/test_stat_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    style="@style/InputStyle"
                    android:hint="Observed statistic"
                    android:visibility="gone">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/test_stat_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal|numberSigned" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Observed χ² value field (kept for backward compat but not shown in new flow) -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/chi_value_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    style="@style/InputStyle"
                    android:hint="Observed χ² value"
                    android:visibility="gone">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/chi_value_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- ── T / χ²: α ── -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/alpha_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    style="@style/InputStyle"
                    android:hint="Significance Level (α), e.g. 0.05"
                    android:visibility="gone">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/alpha_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:text="0.05" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- ── F: df1 ── -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/df1_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    style="@style/InputStyle"
                    android:hint="Numerator Degrees of Freedom (df₁)"
                    android:visibility="gone">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/df1_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- ── F: df2 ── -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/df2_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    style="@style/InputStyle"
                    android:hint="Denominator Degrees of Freedom (df₂)"
                    android:visibility="gone">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/df2_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- F observed value (kept hidden — not needed in simplified flow) -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/f_value_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    style="@style/InputStyle"
                    android:hint="F-value (observed statistic)"
                    android:visibility="gone">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/f_value_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- ── F: α ── -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/f_alpha_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    style="@style/InputStyle"
                    android:hint="Significance Level (α), e.g. 0.05"
                    android:visibility="gone">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/f_alpha_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:text="0.05" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- ── LOG: base ── -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/log_base_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    style="@style/InputStyle"
                    android:hint="Base  (e.g. 3 for log₃)"
                    android:visibility="gone">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/log_base_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- ── LOG: value ── -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/log_value_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    style="@style/InputStyle"
                    android:hint="Value  (e.g. 25)"
                    android:visibility="gone">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/log_value_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal" />
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Calculate Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/calculate_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Calculate"
            style="@style/PrimaryButton"
            android:layout_marginBottom="16dp" />

        <!-- Results Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/results_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Results"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/result_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:lineSpacingExtra="4dp"
                    android:fontFamily="monospace" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Graph Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/graph_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Distribution Graph"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="12dp" />

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/distribution_chart"
                    android:layout_width="match_parent"
                    android:layout_height="280dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>